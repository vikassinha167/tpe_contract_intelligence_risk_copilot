# ---- Azure Key Vault ----
AZURE_KEY_VAULT_URL=https://<your-kv>.vault.azure.net/

# ---- Azure Blob ----
AZURE_STORAGE_ACCOUNT_URL=https://<account>.blob.core.windows.net
AZURE_BLOB_CONTAINER=contracts

# ---- Azure Document Intelligence ----
AZURE_DOCINTEL_ENDPOINT=https://<docintel>.cognitiveservices.azure.com/

# ---- Azure Language Service ----
AZURE_LANGUAGE_ENDPOINT=https://<lang>.cognitiveservices.azure.com/

# ---- Azure OpenAI (via AI Foundry project) ----
AZURE_OPENAI_ENDPOINT=https://<aoai>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---- Azure AI Foundry project ----
AZURE_AI_PROJECT_CONNECTION_STRING=<region>.api.azureml.ms;<sub-id>;<rg>;<project>

# ---- Content Safety / Guardrails ----
AZURE_CONTENT_SAFETY_ENDPOINT=https://<cs>.cognitiveservices.azure.com/

# ---- Logging ----
LOG_LEVEL=INFO
